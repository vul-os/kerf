/* CTS buffer cells fixture for clock-tree synthesis tests.
 * Values are representative for SKY130-style timing.
 * Units: capacitance in pF, delay in ns.
 */

library (cts_buffers) {

    technology (cmos);
    delay_model : table_lookup;
    nom_process : 1.0;
    nom_temperature : 25.0;
    nom_voltage : 1.8;

    /* Simple 1-D template: just output cap, no input transition axis */
    lu_table_template (buf_delay_1d) {
        variable_1 : total_output_net_capacitance;
        index_1 ("0.001, 0.01, 0.1, 1.0");
    }

    /* ------------------------------------------------------------------ */
    /* CLKBUF_1 — weak 1x buffer, max cap 0.05 pF                         */
    /* ------------------------------------------------------------------ */
    cell (sky130_fd_sc_hd__clkbuf_1) {
        area : 3.0;
        cell_leakage_power : 0.001;

        pin (A) {
            direction    : input;
            capacitance  : 0.0015;
            max_capacitance : 0.05;
        }

        pin (X) {
            direction : output;
            function  : "A";

            timing () {
                related_pin  : "A";
                timing_type  : combinational;
                timing_sense : positive_unate;

                cell_rise (buf_delay_1d) {
                    values ("0.050, 0.080, 0.150, 0.400");
                }

                cell_fall (buf_delay_1d) {
                    values ("0.040, 0.070, 0.130, 0.350");
                }

                rise_transition (buf_delay_1d) {
                    values ("0.010, 0.020, 0.060, 0.180");
                }

                fall_transition (buf_delay_1d) {
                    values ("0.008, 0.018, 0.055, 0.160");
                }
            }
        }
    }

    /* ------------------------------------------------------------------ */
    /* CLKBUF_4 — medium 4x buffer, max cap 0.20 pF                       */
    /* ------------------------------------------------------------------ */
    cell (sky130_fd_sc_hd__clkbuf_4) {
        area : 6.0;
        cell_leakage_power : 0.003;

        pin (A) {
            direction    : input;
            capacitance  : 0.004;
            max_capacitance : 0.20;
        }

        pin (X) {
            direction : output;
            function  : "A";

            timing () {
                related_pin  : "A";
                timing_type  : combinational;
                timing_sense : positive_unate;

                cell_rise (buf_delay_1d) {
                    values ("0.045, 0.070, 0.120, 0.300");
                }

                cell_fall (buf_delay_1d) {
                    values ("0.038, 0.060, 0.100, 0.260");
                }

                rise_transition (buf_delay_1d) {
                    values ("0.008, 0.016, 0.048, 0.140");
                }

                fall_transition (buf_delay_1d) {
                    values ("0.007, 0.014, 0.042, 0.125");
                }
            }
        }
    }

    /* ------------------------------------------------------------------ */
    /* CLKBUF_8 — strong 8x buffer, max cap 0.40 pF                       */
    /* ------------------------------------------------------------------ */
    cell (sky130_fd_sc_hd__clkbuf_8) {
        area : 10.0;
        cell_leakage_power : 0.006;

        pin (A) {
            direction    : input;
            capacitance  : 0.008;
            max_capacitance : 0.40;
        }

        pin (X) {
            direction : output;
            function  : "A";

            timing () {
                related_pin  : "A";
                timing_type  : combinational;
                timing_sense : positive_unate;

                cell_rise (buf_delay_1d) {
                    values ("0.042, 0.065, 0.110, 0.270");
                }

                cell_fall (buf_delay_1d) {
                    values ("0.035, 0.055, 0.090, 0.230");
                }

                rise_transition (buf_delay_1d) {
                    values ("0.006, 0.013, 0.040, 0.120");
                }

                fall_transition (buf_delay_1d) {
                    values ("0.005, 0.011, 0.036, 0.110");
                }
            }
        }
    }

} /* end library */
