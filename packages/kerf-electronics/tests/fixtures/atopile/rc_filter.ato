import Resistor from "generics/resistors.ato"
import Capacitor from "generics/capacitors.ato"

module RCFilter:
    signal vin
    signal vout
    signal gnd
    r1 = new Resistor
    r1.value = 1kohm
    c1 = new Capacitor
    c1.value = 100nF
    r1.p1 ~ vin
    r1.p2 ~ vout
    c1.p1 ~ vout
    c1.p2 ~ gnd
