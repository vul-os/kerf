# Kerf deploy env template — the single source of truth.
#   cp .env.z.example .env.dev    # fill in, deploy: ./scripts/deploy-fly.sh --dev
#   cp .env.z.example .env.main   # fill in, deploy: ./scripts/deploy-fly.sh
# .env.dev / .env.main are gitignored (real secrets). deploy-fly.sh blocks
# while any value still contains XXX. Swap dev.kerf.sh → kerf.sh for main.

# ── Mode ─────────────────────────────────────────────────────────────────────
CLOUD_ENABLED=true
KERF_LOCAL_MODE=false
# Cloud beta: billing UI greyed out, no Paystack needed; FX/pricing still run.
KERF_CLOUD_BETA=true

# ── Core secrets ─────────────────────────────────────────────────────────────
# Neon (recommended) or fly postgres. QUOTE the value — the Neon URL's '&'
# breaks bash `source` when unquoted.
DATABASE_URL='XXX_POSTGRES_URL'
# openssl rand -base64 48
JWT_SECRET=XXX_RANDOM_SECRET

# ── Object storage (Tigris: flyctl storage create -a <app>) ──────────────────
KERF_STORAGE_S3_BUCKET=XXX_BUCKET
KERF_STORAGE_S3_ACCESS_KEY=XXX_TIGRIS_ACCESS_KEY
KERF_STORAGE_S3_SECRET_KEY=XXX_TIGRIS_SECRET_KEY
KERF_STORAGE_S3_ENDPOINT=https://fly.storage.tigris.dev
KERF_STORAGE_S3_REGION=auto

# ── Domain / CORS (kerf.sh for main, dev.kerf.sh for dev) ────────────────────
CORS_ORIGIN=https://dev.kerf.sh
VITE_API_URL=https://dev.kerf.sh

# ── Google OAuth (single source: backend reads VITE_GOOGLE_CLIENT_ID) ────────
VITE_GOOGLE_CLIENT_ID=XXX_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=XXX_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URL=https://dev.kerf.sh/auth/google/callback

# ── GitHub OAuth (cloud Git sync) ────────────────────────────────────────────
CLOUD_GITHUB_CLIENT_ID=XXX_GITHUB_CLIENT_ID
CLOUD_GITHUB_CLIENT_SECRET=XXX_GITHUB_CLIENT_SECRET
CLOUD_GITHUB_REDIRECT_URL=https://dev.kerf.sh/auth/github/callback

# ── LLM providers (var names match kerf_core.config; ≥1 recommended) ─────────
ANTHROPIC_API_KEY=XXX_ANTHROPIC_API_KEY
MOONSHOT_API_KEY=XXX_MOONSHOT_API_KEY
GEMINI_API_KEY=XXX_GEMINI_API_KEY

# ── Transactional email (provider: smtp | resend | ses) ──────────────────────
EMAIL_PROVIDER=resend
EMAIL_FROM='Kerf <noreply@kerf.sh>'
RESEND_API_KEY=XXX_RESEND_API_KEY
