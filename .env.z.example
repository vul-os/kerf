# Kerf deploy env template — the single source of truth.
#   cp .env.z.example .env.dev    # fill in, deploy: ./scripts/deploy-fly.sh --dev
#   cp .env.z.example .env.main   # fill in, deploy: ./scripts/deploy-fly.sh
# .env.dev / .env.main are gitignored (real secrets). deploy-fly.sh blocks
# while any value still contains XXX. Swap dev.kerf.sh → kerf.sh for main.
#
# Stack: Fly.io (app + workers) · Neon (Postgres) · Cloudflare R2 (blobs)
#        · RunPod Serverless (GPU renders) · Resend (email).

# ── Mode ─────────────────────────────────────────────────────────────────────
# ENV gates production secret enforcement: anything other than
# local/dev/development/test refuses to boot with dev-default secrets.
ENV=dev                 # set ENV=production for the main deploy
CLOUD_ENABLED=true
KERF_LOCAL_MODE=false
# Cloud beta: billing UI greyed out, no Paystack needed; FX/pricing still run.
KERF_CLOUD_BETA=true
# Fly runs persistent VMs, so the background job loop runs in-process.
KERF_INPROCESS_WORKERS=true

# ── Core secrets ─────────────────────────────────────────────────────────────
# Neon Postgres. QUOTE the value — the Neon URL's '&' breaks bash `source`.
DATABASE_URL='XXX_NEON_POSTGRES_URL'
# openssl rand -base64 48
JWT_SECRET=XXX_RANDOM_SECRET
# openssl rand -base64 32  (required in production; must differ from the dev default)
PASSWORD_PEPPER=XXX_RANDOM_PEPPER

# ── Object storage — Cloudflare R2 (S3-compatible, zero egress) ──────────────
# Create a bucket at dash.cloudflare.com → R2, then an R2 API token (S3 creds).
# Endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com  ·  region is always "auto".
# STORAGE_BACKEND MUST be "s3" or the S3_* vars are ignored (backend stays local).
STORAGE_BACKEND=s3
KERF_STORAGE_S3_BUCKET=XXX_R2_BUCKET
KERF_STORAGE_S3_ACCESS_KEY=XXX_R2_ACCESS_KEY_ID
KERF_STORAGE_S3_SECRET_KEY=XXX_R2_SECRET_ACCESS_KEY
KERF_STORAGE_S3_ENDPOINT=https://XXX_ACCOUNT_ID.r2.cloudflarestorage.com
KERF_STORAGE_S3_REGION=auto
# Public read URL for served blobs — an R2 custom domain or the r2.dev URL.
S3_PUBLIC_URL_BASE=https://XXX_R2_PUBLIC_DOMAIN

# ── GPU renders — RunPod Serverless (Blender Cycles) ─────────────────────────
# Used by the render-dispatch backend. Secure Cloud endpoint for production.
RUNPOD_API_KEY=XXX_RUNPOD_API_KEY
RUNPOD_ENDPOINT_ID=XXX_RUNPOD_SERVERLESS_ENDPOINT_ID

# ── Domain / CORS (kerf.sh for main, dev.kerf.sh for dev) ────────────────────
CORS_ORIGIN=https://dev.kerf.sh
VITE_API_URL=https://dev.kerf.sh

# ── Google OAuth (single source: backend reads VITE_GOOGLE_CLIENT_ID) ────────
VITE_GOOGLE_CLIENT_ID=XXX_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=XXX_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URL=https://dev.kerf.sh/auth/google/callback

# ── GitHub App (login + repo sync) ───────────────────────────────────────────
# Values from the GitHub App settings page. Private key: download the .pem,
# then  base64 -i key.pem | tr -d '\n'  and paste as *_PRIVATE_KEY_B64.
CLOUD_GITHUB_APP_ID=XXX_GITHUB_APP_ID
CLOUD_GITHUB_CLIENT_ID=XXX_GITHUB_APP_CLIENT_ID
CLOUD_GITHUB_CLIENT_SECRET=XXX_GITHUB_APP_CLIENT_SECRET
CLOUD_GITHUB_PRIVATE_KEY_B64=XXX_BASE64_OF_PRIVATE_KEY_PEM
CLOUD_GITHUB_REDIRECT_URL=https://dev.kerf.sh/auth/github/login/callback

# ── LLM providers (var names match kerf_core.config; ≥1 recommended) ─────────
ANTHROPIC_API_KEY=XXX_ANTHROPIC_API_KEY
OPENAI_API_KEY=XXX_OPENAI_API_KEY
MOONSHOT_API_KEY=XXX_MOONSHOT_API_KEY
GEMINI_API_KEY=XXX_GEMINI_API_KEY

# ── Transactional email (pluggable: smtp | resend | ses) ─────────────────────
# Our hosted cloud uses Resend today; SES is the planned migration (flip
# EMAIL_PROVIDER=ses + set the SES_* vars — no code change). Self-host can use
# plain SMTP with no vendor.
EMAIL_PROVIDER=resend
EMAIL_FROM='Kerf <noreply@kerf.sh>'
# resend: set the API key below.
RESEND_API_KEY=XXX_RESEND_API_KEY
# smtp (self-host / generic): EMAIL_PROVIDER=smtp + these.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=XXX_SMTP_USER
# SMTP_PASSWORD=XXX_SMTP_PASS
# ses (planned): EMAIL_PROVIDER=ses + these.
# SES_REGION=us-east-1
# SES_ACCESS_KEY_ID=XXX_SES_ACCESS_KEY
# SES_SECRET_ACCESS_KEY=XXX_SES_SECRET_KEY
