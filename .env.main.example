# Template for .env.main — copy to .env.main and fill in.
#   cp .env.main.example .env.main
# .env.main is gitignored (real secrets). Deploy: ./scripts/deploy-fly.sh
# fly apps: kerf-prod / kerf-workers (org: kerf, region: fra; domain kerf.sh)

CLOUD_ENABLED=true
KERF_LOCAL_MODE=false
# Cloud beta: no Paystack required. Flip to false + add CLOUD_PAYSTACK_*
# to start charging post-launch (see packages/kerf-billing/CLOUD_BETA.md).
KERF_CLOUD_BETA=true

DATABASE_URL=XXX_NEON_PROD_POSTGRES_URL
# openssl rand -base64 48
JWT_SECRET=XXX_GENERATE_A_RANDOM_SECRET

# Tigris bucket for prod (flyctl storage create -a kerf-prod).
KERF_STORAGE_S3_BUCKET=kerf-prod-storage
KERF_STORAGE_S3_ACCESS_KEY=XXX_TIGRIS_ACCESS_KEY
KERF_STORAGE_S3_SECRET_KEY=XXX_TIGRIS_SECRET_KEY
KERF_STORAGE_S3_ENDPOINT=https://fly.storage.tigris.dev
KERF_STORAGE_S3_REGION=auto

CORS_ORIGIN=https://kerf.sh
VITE_API_URL=https://kerf.sh

GOOGLE_CLIENT_ID=XXX_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=XXX_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URL=https://kerf.sh/auth/google/callback
VITE_GOOGLE_CLIENT_ID=XXX_GOOGLE_CLIENT_ID

CLOUD_GITHUB_CLIENT_ID=XXX_GITHUB_CLIENT_ID
CLOUD_GITHUB_CLIENT_SECRET=XXX_GITHUB_CLIENT_SECRET
CLOUD_GITHUB_REDIRECT_URL=https://kerf.sh/auth/github/callback

ANTHROPIC_API_KEY=XXX_ANTHROPIC_API_KEY
MOONSHOT_API_KEY=XXX_MOONSHOT_API_KEY
GEMINI_API_KEY=XXX_GEMINI_API_KEY
