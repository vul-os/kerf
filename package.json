{
  "name": "kerf",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "init": "node ./scripts/init-config.mjs",
    "build:docs": "node ./scripts/build-docs-manifest.mjs",
    "build:icons": "node ./scripts/build-icons.mjs",
    "prebuild:compare": "node ./scripts/build-compare-manifest.mjs",
    "prebuild:roadmap": "node ./scripts/build-roadmap-manifest.mjs",
    "predev": "node ./scripts/init-config.mjs && node ./scripts/build-docs-manifest.mjs && node ./scripts/build-compare-manifest.mjs && node ./scripts/build-roadmap-manifest.mjs",
    "dev": "concurrently -k --kill-signal SIGTERM -n web,api -c cyan,magenta \"vite\" \"kerf-server --reload --host 0.0.0.0 --port 8080\"",
    "dev:web": "vite",
    "dev:api": "kerf-server --reload --host 0.0.0.0 --port 8080",
    "premigrate": "node ./scripts/init-config.mjs",
    "migrate": "python3 -m kerf_core.db.migrations.runner \"$DATABASE_URL\"",
    "migrate:reset": "python3 -m kerf_core.db.migrations.runner \"$DATABASE_URL\" --reset",
    "build": "npm run build:web",
    "prebuild:web": "node ./scripts/build-docs-manifest.mjs && node ./scripts/build-compare-manifest.mjs && node ./scripts/build-roadmap-manifest.mjs",
    "build:web": "vite build",
    "start": "kerf-server --host 0.0.0.0 --port 8080",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "cd tests/e2e && npm test",
    "test:e2e:ui": "cd tests/e2e && npm run test:ui"
  },
  "dependencies": {
    "@jscad/modeling": "^2.12.1",
    "@monaco-editor/react": "^4.6.0",
    "@salusoft89/planegcs": "^1.1.7",
    "@tscircuit/core": "^0.0.1231",
    "@tscircuit/footprinter": "^0.0.351",
    "circuit-json": "^0.0.423",
    "circuit-to-svg": "^0.0.345",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "highlight.js": "^11.11.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.468.0",
    "mathjs": "^15.2.0",
    "occt-import-js": "^0.0.23",
    "opencascade.js": "^1.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sucrase": "^3.35.1",
    "svg2pdf.js": "^2.7.0",
    "three": "^0.160.0",
    "three-mesh-bvh": "^0.9.9",
    "tscircuit": "^0.0.1736",
    "uplot": "^1.6.31",
    "web-ifc": "^0.0.77",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.5.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
