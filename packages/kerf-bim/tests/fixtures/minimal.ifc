ISO-10303-21;
HEADER;
FILE_DESCRIPTION(('Kerf minimal test fixture'),'2;1');
FILE_NAME('minimal.ifc','2024-01-01T00:00:00',('Kerf'),('Kerf'),'IfcOpenShell','IfcOpenShell','');
FILE_SCHEMA(('IFC4'));
ENDSEC;
DATA;
/* Units */
#1=IFCSIUNIT(*,.LENGTHUNIT.,.MILLI.,.METRE.);
#2=IFCSIUNIT(*,.AREAUNIT.,$,.SQUARE_METRE.);
#3=IFCSIUNIT(*,.VOLUMEUNIT.,$,.CUBIC_METRE.);
#4=IFCUNITASSIGNMENT((#1,#2,#3));
/* Geometry context */
#5=IFCCARTESIANPOINT((0.,0.,0.));
#6=IFCDIRECTION((0.,0.,1.));
#7=IFCDIRECTION((1.,0.,0.));
#8=IFCAXIS2PLACEMENT3D(#5,#6,#7);
#9=IFCGEOMETRICREPRESENTATIONCONTEXT($,'Model',3,1.E-05,#8,$);
/* Project */
#10=IFCPROJECT('0000000000000000000000','$','Test Project',$,$,$,$,(#9),#4);
/* Site */
#11=IFCCARTESIANPOINT((0.,0.,0.));
#12=IFCAXIS2PLACEMENT3D(#11,$,$);
#13=IFCLOCALPLACEMENT($,#12);
#14=IFCSITE('1111111111111111111111','$','Main Site',$,$,#13,$,$,.ELEMENT.,(0,0,0,0),(0,0,0,0),0.,$,$);
/* Building */
#15=IFCCARTESIANPOINT((0.,0.,0.));
#16=IFCAXIS2PLACEMENT3D(#15,$,$);
#17=IFCLOCALPLACEMENT(#13,#16);
#18=IFCBUILDING('2222222222222222222222','$','Test Building',$,$,#17,$,$,.ELEMENT.,$,$,$);
/* Level / Storey */
#19=IFCCARTESIANPOINT((0.,0.,0.));
#20=IFCAXIS2PLACEMENT3D(#19,$,$);
#21=IFCLOCALPLACEMENT(#17,#20);
#22=IFCBUILDINGSTOREY('3333333333333333333333','$','L1',$,$,#21,$,$,.ELEMENT.,0.);
/* Aggregation relationships */
#23=IFCRELAGGREGATES('A000000000000000000001','$',$,$,#10,(#14));
#24=IFCRELAGGREGATES('A000000000000000000002','$',$,$,#14,(#18));
#25=IFCRELAGGREGATES('A000000000000000000003','$',$,$,#18,(#22));
/* Wall geometry */
#30=IFCCARTESIANPOINT((2500.,0.,0.));
#31=IFCDIRECTION((1.,0.,0.));
#32=IFCDIRECTION((0.,0.,1.));
#33=IFCAXIS2PLACEMENT3D(#30,#32,#31);
#34=IFCRECTANGLEPROFILEDEF(.AREA.,$,#33,5000.,200.);
#35=IFCCARTESIANPOINT((0.,0.,0.));
#36=IFCDIRECTION((0.,0.,1.));
#37=IFCAXIS2PLACEMENT3D(#35,#36,$);
#38=IFCEXTRUDEDAREASOLID(#34,#37,#36,3000.);
#39=IFCSHAPEREPRESENTATION(#9,'Body','SweptSolid',(#38));
#40=IFCPRODUCTDEFINITIONSHAPE($,$,(#39));
/* Wall placement */
#41=IFCCARTESIANPOINT((0.,0.,0.));
#42=IFCAXIS2PLACEMENT3D(#41,$,$);
#43=IFCLOCALPLACEMENT(#21,#42);
/* Wall entity */
#50=IFCWALLSTANDARDCASE('4444444444444444444444','$','TestWall',$,$,#43,#40,$);
/* Containment */
#51=IFCRELCONTAINEDINSPATIALSTRUCTURE('C000000000000000000001','$',$,$,(#50),#22);
ENDSEC;
END-ISO-10303-21;
